rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: anyone authenticated can read (for matching list, profiles); only own doc writable
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Match requests: only sender or receiver can read/write
    match /match_requests/{requestId} {
      allow create: if request.auth != null
        && request.resource.data.sender_id == request.auth.uid;
      allow read, update, delete: if request.auth != null
        && (resource.data.sender_id == request.auth.uid
            || resource.data.receiver_id == request.auth.uid);
    }

    // Anonymous matches: only participants can read/write
    match /anonymous_matches/{matchId} {
      allow create: if request.auth != null
        && (request.resource.data.user1_id == request.auth.uid
            || request.resource.data.user2_id == request.auth.uid);
      allow read, update, delete: if request.auth != null
        && (resource.data.user1_id == request.auth.uid
            || resource.data.user2_id == request.auth.uid);
    }

    // Match messages: any authenticated user (app restricts by match membership)
    match /match_messages/{messageId} {
      allow read, write: if request.auth != null;
    }

    // Conversations (DMs): only participants can read/write
    match /conversations/{convId} {
      allow create: if request.auth != null
        && (request.resource.data.participant1_id == request.auth.uid
            || request.resource.data.participant2_id == request.auth.uid);
      allow read, update, delete: if request.auth != null
        && (resource.data.participant1_id == request.auth.uid
            || resource.data.participant2_id == request.auth.uid);
    }

    // Messages in conversations
    match /messages/{messageId} {
      allow read, write: if request.auth != null;
    }

    // Posts, comments, votes, followers, etc.
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if request.auth != null;
    }
    match /comments/{commentId} {
      allow read, write: if request.auth != null;
    }
    match /postVotes/{voteId} {
      allow read, write: if request.auth != null;
    }
    match /followers/{followerId} {
      allow read, write: if request.auth != null;
    }
    match /login_logs/{logId} {
      allow read, write: if request.auth != null;
    }

    // Groups
    match /groups/{groupId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }
    match /group_members/{memberId} {
      allow read, write: if request.auth != null;
    }
    match /group_activities/{activityId} {
      allow read, write: if request.auth != null;
    }
    match /group_streak_proofs/{proofId} {
      allow read, write: if request.auth != null;
    }
    match /group_messages/{messageId} {
      allow read, write: if request.auth != null;
    }
    match /used_challenge_ideas/{ideaId} {
      allow read, create: if request.auth != null;
    }

    // In-app notifications (match accepted, game invites, moderation, etc.)
    // Simpler rule: any signed-in user can read/write only their own docs by app logic,
    // but rules do not block queries (avoids permission issues on composite queries).
    match /notifications/{notifId} {
      allow read, create, update, delete: if request.auth != null;
    }

    // Therapist onboarding requests:
    // - Public users create requests via Cloud Functions, not direct writes.
    // - Admins can read/update/delete any request.
    // - Therapists can update their own request (to mark onboarding completed).
    match /therapist_onboarding_requests/{requestId} {
      // Admin powers
      allow read, update, delete: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.is_admin == true;

      // Therapist can update their own request based on email match
      allow update: if request.auth != null
        && resource.data.email == request.auth.token.email;

      // No direct client creates; use submitTherapistRequest callable instead.
      allow create: if false;
    }
  }
}
