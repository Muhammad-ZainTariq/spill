rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.is_admin == true
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.is_admin == 'true'
        );
    }

    // Users: anyone authenticated can read (for matching list, profiles); only own doc writable
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Match requests: only sender or receiver can read/write
    match /match_requests/{requestId} {
      allow create: if request.auth != null
        && request.resource.data.sender_id == request.auth.uid;
      allow read, update, delete: if request.auth != null
        && (resource.data.sender_id == request.auth.uid
            || resource.data.receiver_id == request.auth.uid);
    }

    // Anonymous matches: only participants can read/write
    match /anonymous_matches/{matchId} {
      allow create: if request.auth != null
        && (request.resource.data.user1_id == request.auth.uid
            || request.resource.data.user2_id == request.auth.uid);
      allow read, update, delete: if request.auth != null
        && (resource.data.user1_id == request.auth.uid
            || resource.data.user2_id == request.auth.uid);
    }

    // Match messages: any authenticated user (app restricts by match membership)
    match /match_messages/{messageId} {
      allow read, write: if request.auth != null;
    }

    // Conversations (DMs): only participants can read/write
    match /conversations/{convId} {
      allow create: if request.auth != null
        && (request.resource.data.participant1_id == request.auth.uid
            || request.resource.data.participant2_id == request.auth.uid);
      allow read, update, delete: if request.auth != null
        && (resource.data.participant1_id == request.auth.uid
            || resource.data.participant2_id == request.auth.uid);
    }

    // Messages in conversations
    match /messages/{messageId} {
      allow read, write: if request.auth != null;
    }

    // Posts, comments, votes, followers, etc.
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if request.auth != null;
    }
    match /comments/{commentId} {
      allow read, write: if request.auth != null;
    }
    match /postVotes/{voteId} {
      allow read, write: if request.auth != null;
    }
    match /followers/{followerId} {
      allow read, write: if request.auth != null;
    }
    match /login_logs/{logId} {
      allow read, write: if request.auth != null;
    }

    // Groups
    match /groups/{groupId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }
    match /group_members/{memberId} {
      allow read, write: if request.auth != null;
    }
    match /group_activities/{activityId} {
      allow read, write: if request.auth != null;
    }
    match /group_streak_proofs/{proofId} {
      allow read, write: if request.auth != null;
    }
    match /group_messages/{messageId} {
      allow read, write: if request.auth != null;
    }
    match /used_challenge_ideas/{ideaId} {
      allow read, create: if request.auth != null;
    }

    // In-app notifications (match accepted, game invites, moderation, etc.)
    // Simpler rule: any signed-in user can read/write only their own docs by app logic,
    // but rules do not block queries (avoids permission issues on composite queries).
    match /notifications/{notifId} {
      allow read, create, update, delete: if request.auth != null;
    }

    // Reports (moderation queue):
    // - system and Cloud Functions can always write
    // - users can create reports for moderation
    // - admins can read/update/resolve
    match /reports/{reportId} {
      allow create: if request.auth != null
        && request.resource.data.reporter_uid == request.auth.uid
        && request.resource.data.created_at is string
        && request.resource.data.status == 'pending';
      allow read, update, delete: if isAdmin();
    }

    // User blocks (DM safety):
    // doc id convention: "{blockerUid}_{blockedUid}"
    match /user_blocks/{blockId} {
      allow create: if request.auth != null
        && request.resource.data.blocker_uid == request.auth.uid
        && request.resource.data.blocked_uid is string;
      allow read: if request.auth != null
        && resource.data.blocker_uid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.blocker_uid == request.auth.uid;
      allow update: if false;
    }

    // Therapist onboarding requests:
    // - Public users create requests via Cloud Functions, not direct writes.
    // - Admins can read/update/delete any request.
    // - Therapists can read/update their own request (by email match).
    match /therapist_onboarding_requests/{requestId} {
      // Admin powers
      allow read, update, delete: if isAdmin();

      // Therapist can read their own request based on email match
      allow read: if request.auth != null
        && resource.data.email == request.auth.token.email;

      // Therapist can update their own request based on email match
      allow update: if request.auth != null
        && resource.data.email == request.auth.token.email;

      // No direct client creates; use submitTherapistRequest callable instead.
      allow create: if false;
    }

    // Public therapist marketplace
    match /therapist_profiles/{therapistId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && (request.auth.uid == therapistId || isAdmin());
      allow delete: if isAdmin();
    }

    match /therapist_slots/{slotId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.therapist_uid == request.auth.uid;
      allow update, delete: if request.auth != null
        && (resource.data.therapist_uid == request.auth.uid || isAdmin());
    }

    // Booking requests (created/updated by Cloud Functions):
    // - therapist + requester + admin can read
    match /therapist_booking_requests/{requestId} {
      allow read: if isAdmin()
        || (request.auth != null && resource.data.therapist_uid == request.auth.uid)
        || (request.auth != null && resource.data.requester_uid == request.auth.uid);
      allow create, update, delete: if false;
    }

    match /therapist_sessions/{sessionId} {
      allow read: if request.auth != null
        && (resource.data.user_uid == request.auth.uid
          || resource.data.therapist_uid == request.auth.uid
          || isAdmin());
      allow create, update, delete: if false; // created/managed by Cloud Functions
    }

    match /therapist_sessions/{sessionId}/messages/{messageId} {
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/therapist_sessions/$(sessionId))
        && (
          get(/databases/$(database)/documents/therapist_sessions/$(sessionId)).data.user_uid == request.auth.uid
          || get(/databases/$(database)/documents/therapist_sessions/$(sessionId)).data.therapist_uid == request.auth.uid
          || isAdmin()
        );
      allow create: if request.auth != null
        && exists(/databases/$(database)/documents/therapist_sessions/$(sessionId))
        && (
          get(/databases/$(database)/documents/therapist_sessions/$(sessionId)).data.user_uid == request.auth.uid
          || get(/databases/$(database)/documents/therapist_sessions/$(sessionId)).data.therapist_uid == request.auth.uid
          || isAdmin()
        )
        && request.resource.data.sender_uid == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.sender_uid == request.auth.uid;
    }

    // Session reviews:
    // - only the patient can create exactly one review per session (docId = patient uid)
    // - only therapist/admin can read reviews (patient cannot)
    match /therapist_sessions/{sessionId}/reviews/{reviewerUid} {
      allow create: if request.auth != null
        && request.auth.uid == reviewerUid
        && exists(/databases/$(database)/documents/therapist_sessions/$(sessionId))
        && get(/databases/$(database)/documents/therapist_sessions/$(sessionId)).data.user_uid == request.auth.uid
        && request.resource.data.reviewer_uid == request.auth.uid
        && request.resource.data.created_at is string
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && !exists(/databases/$(database)/documents/therapist_sessions/$(sessionId)/reviews/$(reviewerUid));

      allow read: if isAdmin()
        || (
          request.auth != null
          && exists(/databases/$(database)/documents/therapist_sessions/$(sessionId))
          && get(/databases/$(database)/documents/therapist_sessions/$(sessionId)).data.therapist_uid == request.auth.uid
        );
      allow update, delete: if false;
    }

    match /therapist_sessions/{sessionId}/signals/{signalId} {
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/therapist_sessions/$(sessionId))
        && (
          get(/databases/$(database)/documents/therapist_sessions/$(sessionId)).data.user_uid == request.auth.uid
          || get(/databases/$(database)/documents/therapist_sessions/$(sessionId)).data.therapist_uid == request.auth.uid
          || isAdmin()
        );

      // Either participant can set a crisis signal, therapist can clear it.
      allow create, update: if request.auth != null
        && exists(/databases/$(database)/documents/therapist_sessions/$(sessionId))
        && (
          // patient can activate
          (
            get(/databases/$(database)/documents/therapist_sessions/$(sessionId)).data.user_uid == request.auth.uid
            && request.resource.data.status in ['active','cleared']
          )
          // therapist can activate/clear
          || (
            get(/databases/$(database)/documents/therapist_sessions/$(sessionId)).data.therapist_uid == request.auth.uid
            && request.resource.data.status in ['active','cleared']
          )
          || isAdmin()
        );
      allow delete: if isAdmin();
    }

    // Aggregated therapist reviews (written by Cloud Functions):
    // Admin + therapist can read, nobody else.
    match /therapist_reviews/{reviewId} {
      allow read: if isAdmin()
        || (request.auth != null && resource.data.therapist_uid == request.auth.uid);
      allow create, update: if false;
      allow delete: if isAdmin();
    }

    // Therapist resources (books, articles, courses) – admin adds, therapists read
    match /therapist_resources/{resourceId} {
      allow read: if request.auth != null
        && (isAdmin()
            || exists(/databases/$(database)/documents/therapist_profiles/$(request.auth.uid)));
      allow create, update, delete: if isAdmin();
    }
  }
}
