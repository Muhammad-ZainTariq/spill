rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Default: deny
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Avatars (user profile images)
    match /avatars/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid != null;
    }

    // Group covers
    match /groups/{groupId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Streak proofs (challenge groups)
    match /group_streak_proofs/{groupId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Therapist verification documents
    // Written by Cloud Functions with admin SDK, but therapists need to be able
    // to read the file via getDownloadURL after upload.
    match /therapist-docs/{userId}/{fileName} {
      allow read: if request.auth != null;
      // No direct client writes; uploads go through the uploadMedia Cloud Function.
      allow write: if false;
    }

    // (Optional) If you later store videos in a separate folder.
    match /therapist-videos/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}

