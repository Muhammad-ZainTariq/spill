rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Specific paths first — the catch-all below must NOT come first or it blocks everything.

    // Avatars (user profile images)
    match /avatars/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid != null;
    }

    // Group covers
    match /groups/{groupId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Streak proofs (challenge groups)
    match /group_streak_proofs/{groupId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Therapist verification documents
    match /therapist-docs/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /therapist-videos/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Therapist resources (PDFs + cover PNGs). Download URLs use access tokens; SDK reads also allowed.
    // Public read: tokenized URLs work without auth; direct GET without token still needs a matching rule.
    match /therapist_resources/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // Default: deny anything not matched above
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
