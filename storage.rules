rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Specific paths first — the catch-all below must NOT come first or it blocks everything.

    // Avatars (user profile images)
    match /avatars/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid != null;
    }

    // Group covers
    match /groups/{groupId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Streak proofs (challenge groups)
    match /group_streak_proofs/{groupId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Therapist verification documents
    match /therapist-docs/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /therapist-videos/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Therapist resources — PDFs by type (books vs articles); Cloud Function uploads; auth reads
    match /therapist_resources/books/{fileName} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /therapist_resources/articles/{fileName} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    // PDF first-page cover PNGs (Cloud Function uploads)
    match /therapist_resources/covers/books/{fileName} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /therapist_resources/covers/articles/{fileName} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    // Legacy flat paths (older uploads before folders)
    match /therapist_resources/{fileName} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Default: deny anything not matched above
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
